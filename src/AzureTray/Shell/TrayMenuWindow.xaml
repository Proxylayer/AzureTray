<Window x:Class="AzureTray.Shell.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:contracts="clr-namespace:AzureTray.Plugin.Contracts;assembly=AzureTray.Plugin.Contracts"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        ShowActivated="True"
        Focusable="True"
        KeyDown="OnKeyDown"
        Deactivated="OnDeactivated">
    <Window.Resources>
        <!-- Shared item template for a single menu row. Renders either a
             6px transparent spacer (separator) or a full row with the
             3-column grid [icon][text][chevron/shortcut].

             IsBusy items get the rotating ◐/◓/◑/◒ glyph through a
             Storyboard targeting the SpinnerText TextBlock — the rest of
             the menu stays still, no full-row redraw. -->
        <Style x:Key="TrayMenuRow" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Accent}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate DataType="{x:Type contracts:PluginMenuItem}">
            <Grid x:Name="Root" Cursor="Hand">
                <!-- Separator path: 6px transparent spacer. The Grid stays
                     in the layout but only this child is visible. -->
                <Border x:Name="SeparatorSpacer" Height="6" Visibility="Collapsed"/>

                <!-- Item path: row content. Plugin-provided icon (if any)
                     gets its own slot so we can animate it for IsBusy. -->
                <Grid x:Name="ItemContent" Margin="14,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Icon slot. Width auto so items without an icon
                         don't waste column space; the gap is achieved via
                         the icon's right margin. -->
                    <TextBlock x:Name="IconText"
                               Grid.Column="0"
                               Text="{Binding Icon}"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Text}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource Brush.Text.Primary}"/>
                    <!-- Favorite star. Own hit target (Background=Transparent
                         + padding) so the code-behind can detect a click on it
                         by name and toggle without firing the row's primary
                         action. Empty ☆ by default; the DataTrigger below
                         swaps to a filled ★ when IsFavorite is true. Hidden
                         entirely on rows where IsFavorite is null. -->
                    <TextBlock x:Name="FavoriteStar"
                               Grid.Column="2"
                               Text="&#x2606;"
                               FontSize="15"
                               Padding="6,0"
                               Margin="10,0,0,0"
                               Cursor="Hand"
                               Background="Transparent"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               Visibility="{Binding ShowFavorite, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock x:Name="Chevron"
                               Grid.Column="3"
                               Text="&#x25B6;"
                               FontSize="10"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               Visibility="{Binding HasChildren, Converter={StaticResource BoolToVisibility}}"/>
                </Grid>
            </Grid>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                    <Setter TargetName="SeparatorSpacer" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ItemContent" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="Root" Property="Cursor" Value="Arrow"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                    <Setter TargetName="Root" Property="Cursor" Value="Arrow"/>
                    <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                </DataTrigger>

                <!-- Favorited rows: filled star in the accent color. The
                     default (false / unfavorited) state keeps the muted ☆
                     from the TextBlock declaration above. -->
                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                    <Setter TargetName="FavoriteStar" Property="Text" Value="&#x2605;"/>
                    <Setter TargetName="FavoriteStar" Property="Foreground" Value="{DynamicResource Brush.Accent}"/>
                </DataTrigger>

                <!-- IsBusy: cycle the icon glyph through ◐ ◓ ◑ ◒ on a
                     480ms loop. ObjectAnimationUsingKeyFrames animates the
                     Text property directly — no rotation transform needed
                     so the spinner reads cleanly at any font size and looks
                     identical to the inline glyph the legacy WinForms menu
                     used. ExitActions stop the storyboard so Text reverts
                     to the bound Icon value when the poll finishes. -->
                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="SpinStory">
                            <Storyboard RepeatBehavior="Forever">
                                <ObjectAnimationUsingKeyFrames
                                    Storyboard.TargetName="IconText"
                                    Storyboard.TargetProperty="Text">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.00" Value="◐"/>
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.12" Value="◓"/>
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.24" Value="◑"/>
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.36" Value="◒"/>
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.48" Value="◐"/>
                                </ObjectAnimationUsingKeyFrames>
                                <ColorAnimation
                                    Storyboard.TargetName="IconText"
                                    Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                    To="{StaticResource Color.Accent}"
                                    Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="SpinStory"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <!-- Bordered surface with subtle drop shadow, rounded corners. The
         Border IS the menu — the Window itself is transparent so we get
         proper rounded edges without OS chrome. -->
    <Border Background="{DynamicResource Brush.Surface.Panel}"
            BorderBrush="{DynamicResource Brush.Border.Default}"
            BorderThickness="1"
            CornerRadius="{DynamicResource Radius.Large}"
            MinWidth="280"
            MaxWidth="520"
            Padding="0,4"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect Color="Black"
                              Opacity="0.55"
                              BlurRadius="16"
                              ShadowDepth="2"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">
            <!-- Search box at the top of searchable submenus. Hidden when
                 the menu wasn't constructed with a SearchProvider. -->
            <Grid DockPanel.Dock="Top"
                  Margin="6,4,6,4"
                  Visibility="{Binding HasSearch, Converter={StaticResource BoolToVisibility}}">
                <TextBox x:Name="SearchBox"
                         TextChanged="OnSearchTextChanged"/>
                <!-- Placeholder overlay: visible only when SearchBox is empty
                     AND not focused. Hit-test invisible so clicks pass to
                     the TextBox beneath. -->
                <TextBlock Text="{Binding SearchPlaceholder}"
                           IsHitTestVisible="False"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.Text.Muted}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Text, ElementName=SearchBox}" Value=""/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- Three-row grid sandwiches the ListBox between scroll
                 indicators. Borders are collapsed by default; the
                 code-behind locates the ListBox's internal ScrollViewer
                 on load and shows/hides each arrow based on
                 VerticalOffset / ScrollableHeight (matches the legacy
                 Azure.PIM.Tray ScrollUpArrow / ScrollDownArrow pattern).
                 Hovering an arrow starts a 50ms DispatcherTimer that
                 scrolls 40 DIP per tick until the cursor leaves. -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border x:Name="ScrollUpArrow"
                        Grid.Row="0"
                        Visibility="Collapsed"
                        Background="{DynamicResource Brush.Surface.Panel}"
                        Padding="0,3"
                        Cursor="Hand"
                        MouseEnter="OnScrollUpArrowMouseEnter"
                        MouseLeave="OnScrollArrowMouseLeave">
                    <TextBlock Text="&#x25B2;"
                               FontSize="8"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               HorizontalAlignment="Center"/>
                </Border>

                <ListBox x:Name="ItemsList"
                         Grid.Row="1"
                         ItemsSource="{Binding Items}"
                         ItemContainerStyle="{StaticResource TrayMenuRow}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0"
                         MaxHeight="500"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Hidden"
                         KeyboardNavigation.DirectionalNavigation="Cycle"
                         MouseLeftButtonUp="OnItemMouseLeftButtonUp"
                         MouseRightButtonUp="OnItemMouseRightButtonUp"
                         SelectionChanged="OnSelectionChanged"
                         Loaded="OnItemsListLoaded"/>

                <Border x:Name="ScrollDownArrow"
                        Grid.Row="2"
                        Visibility="Collapsed"
                        Background="{DynamicResource Brush.Surface.Panel}"
                        Padding="0,3"
                        Cursor="Hand"
                        MouseEnter="OnScrollDownArrowMouseEnter"
                        MouseLeave="OnScrollArrowMouseLeave">
                    <TextBlock Text="&#x25BC;"
                               FontSize="8"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</Window>
