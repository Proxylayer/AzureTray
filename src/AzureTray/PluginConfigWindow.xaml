<Window x:Class="AzureTray.PluginConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Plugin configuration"
        Width="520" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource Brush.Surface.Base}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FontFamily="{DynamicResource Font.Family.UI}"
        FontSize="{DynamicResource Font.Size.Body}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Grid Margin="{StaticResource Padding.Window}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding DisplayName}"
                           Style="{StaticResource Text.Display}"/>
                <TextBlock Text="{Binding Version, StringFormat=' v{0}'}"
                           Style="{StaticResource Text.Muted}"
                           VerticalAlignment="Bottom"
                           Margin="6,0,0,6"/>
            </StackPanel>
            <TextBlock Text="{Binding PluginId}"
                       Style="{StaticResource Text.Muted}"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Tenant enable grid -->
                <Border Style="{StaticResource Card}"
                        Visibility="{Binding HasTenants, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Enabled for tenants"
                                   Style="{StaticResource Text.Subheading}"
                                   Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding Tenants}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}"
                                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                              Margin="0,3"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Generic option editors -->
                <Border Style="{StaticResource Card}"
                        Margin="{StaticResource Margin.CardGap}"
                        Visibility="{Binding HasOptions, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Options"
                                   Style="{StaticResource Text.Subheading}"
                                   Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding Options}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Label}"/>
                                            <TextBlock Text="{Binding Description}"
                                                       TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Muted}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Description}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1"
                                                  IsChecked="{Binding BoolValue, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Right"
                                                  Visibility="{Binding ShowsPlainBooleanCheckbox, Converter={StaticResource BoolToVisibility}}"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding TextValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalAlignment="Center"
                                                 Visibility="{Binding IsText, Converter={StaticResource BoolToVisibility}}"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding NumberValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalAlignment="Center"
                                                 Visibility="{Binding IsNumber, Converter={StaticResource BoolToVisibility}}"/>
                                        <!-- Compound row: a Boolean checkbox that gates a companion option's
                                             editor (e.g. "[x] Clear after [5] minutes"). Renders in place of
                                             the standalone CheckBox when this option has a Companion. -->
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Right"
                                                    Visibility="{Binding HasCompanion, Converter={StaticResource BoolToVisibility}}">
                                            <CheckBox IsChecked="{Binding BoolValue, Mode=TwoWay}"
                                                      VerticalAlignment="Center"/>
                                            <TextBox Text="{Binding Companion.NumberValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding BoolValue}"
                                                     Width="56"
                                                     Margin="8,0,4,0"
                                                     VerticalAlignment="Center"
                                                     HorizontalContentAlignment="Right"/>
                                            <TextBlock Text="{Binding Companion.Label}"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource Text.Muted}"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Plugin-provided custom UserControl -->
                <Border Style="{StaticResource Card}"
                        Margin="{StaticResource Margin.CardGap}"
                        Visibility="{Binding HasCustomView, Converter={StaticResource BoolToVisibility}}">
                    <ContentControl Content="{Binding CustomView}"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Close"
                    Width="90"
                    Click="CloseClick"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
