<Window x:Class="AzureTray.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:logging="clr-namespace:AzureTray.Logging"
        Title="Log Viewer"
        Width="1100" Height="600"
        MinWidth="700" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource Brush.Surface.Base}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FontFamily="{DynamicResource Font.Family.UI}"
        FontSize="{DynamicResource Font.Size.Body}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <logging:LevelToBrushConverter x:Key="LevelToBrush"/>
        <logging:LevelToGlyphConverter x:Key="LevelToGlyph"/>
        <logging:NullToVisibilityConverter x:Key="NullToVisibility"/>

        <!-- Soften the ListBox selection so accent-blue doesn't drown out
             the row text. Same pattern as the Plugins card on Settings. -->
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                         Color="{StaticResource Color.Accent}" Opacity="0.22"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                         Color="{StaticResource Color.Text.Primary}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                         Color="{StaticResource Color.Accent}" Opacity="0.16"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
                         Color="{StaticResource Color.Text.Primary}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"
                         Color="{StaticResource Color.Accent}" Opacity="0.16"/>

        <FontFamily x:Key="Font.Mono">Cascadia Mono, Consolas, Menlo, Monaco, Courier New, monospace</FontFamily>

        <!-- Form-row label style copied from SettingsWindow.xaml; localised
             here so the LogViewer doesn't take a transitive dep on it. -->
        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="{StaticResource Padding.Window}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header. Title on the left, fast actions on the right. -->
        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
            <TextBlock DockPanel.Dock="Left"
                       Text="Log Viewer"
                       Style="{StaticResource Text.Heading}"
                       VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right"
                    Content="Clear log"
                    Margin="8,0,0,0"
                    Command="{Binding ClearLogCommand}"/>
            <Button DockPanel.Dock="Right"
                    Content="Clear filters"
                    Margin="8,0,0,0"
                    Command="{Binding ClearFiltersCommand}"/>
            <Button DockPanel.Dock="Right"
                    Content="Open log folder"
                    Margin="8,0,0,0"
                    Command="{Binding OpenLogsFolderCommand}"/>
            <CheckBox DockPanel.Dock="Right"
                      Content="Log to disk"
                      IsChecked="{Binding LogToDisk, Mode=TwoWay}"
                      ToolTip="{Binding LogsDirectory, StringFormat='Writes log files to {0}'}"
                      VerticalAlignment="Center"
                      Margin="16,0,0,0"/>
            <CheckBox DockPanel.Dock="Right"
                      Content="Auto-scroll"
                      IsChecked="{Binding AutoScroll, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      Margin="16,0,0,0"/>
        </DockPanel>

        <!-- Single filter row: capture level, type, class, search. -->
        <Border Grid.Row="1"
                Style="{StaticResource Card}"
                Padding="10"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Capture" Style="{StaticResource FilterLabel}"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailableLevels}"
                          SelectedItem="{Binding SelectedLevel, Mode=TwoWay}"
                          ToolTip="Minimum severity Serilog will admit to the buffer. Below this, events are dropped."/>

                <TextBlock Grid.Column="3" Text="Show" Style="{StaticResource FilterLabel}"/>
                <ComboBox Grid.Column="4"
                          ItemsSource="{Binding TypeFilterOptions}"
                          SelectedItem="{Binding SelectedTypeFilter, Mode=TwoWay}"
                          ToolTip="Filter the visible list to one severity. Capture above still admits all levels at and above Capture."/>

                <TextBlock Grid.Column="6" Text="Class" Style="{StaticResource FilterLabel}"/>
                <ComboBox Grid.Column="7"
                          ItemsSource="{Binding ClassOptionsView}"
                          SelectedItem="{Binding SelectedClassOption, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          ToolTip="Filter by source. Click a class name on any row to pin it here.">
                    <ComboBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Text.Secondary}"
                                               Margin="4,4,0,2"/>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ComboBox.GroupStyle>
                </ComboBox>

                <TextBlock Grid.Column="9" Text="Search" Style="{StaticResource FilterLabel}"/>
                <TextBox Grid.Column="10"
                         Text="{Binding MessageFilter, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Case-insensitive substring match against the message body AND any attached exception text."/>
            </Grid>
        </Border>

        <!-- Log rows. ListBox + custom item template — wraps long messages,
             colour-codes severity, keeps the class as muted right-aligned
             secondary text. Virtualisation on for smooth scroll at 500
             rows. -->
        <Border Grid.Row="2"
                Background="{StaticResource Brush.Surface.Panel}"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Medium}">
            <ListBox x:Name="EntriesList"
                     ItemsSource="{Binding EntriesView}"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel">
                <ListBox.Resources>
                    <!-- Compact padding on each row container; the template
                         below controls the actual margins. -->
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.Resources>
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Copy row" Click="CopyRowClick"/>
                        <MenuItem Header="Copy message" Click="CopyMessageClick"/>
                        <MenuItem Header="Copy exception" Click="CopyExceptionClick"/>
                        <Separator Style="{StaticResource MenuSeparator}"/>
                        <MenuItem Header="Copy all visible rows" Click="CopyAllRowsClick"/>
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,5,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3"/>    <!-- severity stripe -->
                                <ColumnDefinition Width="6"/>    <!-- spacer -->
                                <ColumnDefinition Width="36"/>   <!-- severity glyph -->
                                <ColumnDefinition Width="92"/>   <!-- timestamp -->
                                <ColumnDefinition Width="*"/>    <!-- message + exception + class -->
                            </Grid.ColumnDefinitions>

                            <!-- Severity stripe: thin vertical accent. -->
                            <Rectangle Grid.Column="0"
                                       Fill="{Binding Level, Converter={StaticResource LevelToBrush}}"
                                       RadiusX="1.5" RadiusY="1.5"
                                       VerticalAlignment="Stretch"/>

                            <!-- Severity glyph: ERR / WRN / INF / DBG / VRB / FTL -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Level, Converter={StaticResource LevelToGlyph}}"
                                       Foreground="{Binding Level, Converter={StaticResource LevelToBrush}}"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Top"
                                       Margin="0,1,0,0"/>

                            <!-- Timestamp: fixed-width monospace, muted. -->
                            <TextBlock Grid.Column="3"
                                       Text="{Binding Timestamp, StringFormat=HH:mm:ss.fff}"
                                       FontFamily="{StaticResource Font.Mono}"
                                       Foreground="{DynamicResource Brush.Text.Muted}"
                                       VerticalAlignment="Top"
                                       Margin="0,1,8,0"/>

                            <!-- Right column: message + exception (if any) +
                                 class. Class is right-aligned on the same
                                 line as the first wrap of the message; it
                                 stays visible even when the message wraps
                                 below it. -->
                            <DockPanel Grid.Column="4">
                                <!-- Class label, right-aligned, click-to-filter. -->
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding Category}"
                                           Foreground="{DynamicResource Brush.Text.Muted}"
                                           FontSize="11"
                                           MaxWidth="240"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Top"
                                           Margin="12,2,0,0"
                                           Cursor="Hand"
                                           ToolTip="{Binding Category, StringFormat='Click to filter by {0}'}">
                                    <TextBlock.InputBindings>
                                        <MouseBinding Gesture="LeftClick"
                                                      Command="{Binding DataContext.FilterByCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding Category}"/>
                                    </TextBlock.InputBindings>
                                </TextBlock>

                                <!-- Message + optional exception, stacked. -->
                                <StackPanel>
                                    <TextBlock Text="{Binding Message}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource Brush.Text.Primary}"
                                               VerticalAlignment="Top"/>
                                    <TextBlock Text="{Binding Exception}"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Brush.Text.Muted}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"
                                               Visibility="{Binding Exception, Converter={StaticResource NullToVisibility}}"/>
                                </StackPanel>
                            </DockPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Button Grid.Row="3"
                Content="Close"
                Width="90"
                HorizontalAlignment="Right"
                Margin="0,10,0,0"
                Click="CloseClick"
                IsCancel="True"/>
    </Grid>
</Window>
