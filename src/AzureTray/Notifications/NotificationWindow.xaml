<Window x:Class="AzureTray.Notifications.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:notif="clr-namespace:AzureTray.Notifications"
        Title="Notification"
        Width="360"
        SizeToContent="Height"
        MinHeight="140"
        MaxHeight="600"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Background="Transparent"
        AllowsTransparency="True"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FontFamily="{DynamicResource Font.Family.UI}"
        FontSize="{DynamicResource Font.Size.Body}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <notif:SeverityToBrushConverter x:Key="SeverityToBrush"/>
    </Window.Resources>

    <Border Background="{DynamicResource Brush.Surface.Panel}"
            BorderBrush="{DynamicResource Brush.Border.Default}"
            BorderThickness="1"
            CornerRadius="{DynamicResource Radius.Large}"
            Padding="0"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect Color="Black"
                              Opacity="0.55"
                              BlurRadius="16"
                              ShadowDepth="2"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="3"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Severity-tinted accent stripe across the top of the card.
                 Blue for Update, amber for Warning, coral for Error, muted
                 grey for Info. -->
            <Rectangle Grid.Row="0"
                       Fill="{Binding Severity, Converter={StaticResource SeverityToBrush}}"
                       RadiusX="6" RadiusY="6"/>

            <DockPanel Grid.Row="1" Margin="14,12,14,0">
                <Button DockPanel.Dock="Right"
                        Content="×"
                        FontSize="16"
                        Width="22" Height="22"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{DynamicResource Brush.Text.Muted}"
                        Cursor="Hand"
                        Command="{Binding DismissCommand}"
                        ToolTip="Dismiss"/>
                <TextBlock Text="{Binding Title}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{Binding Severity, Converter={StaticResource SeverityToBrush}}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>

            <TextBlock Grid.Row="2"
                       Text="{Binding Message}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource Brush.Text.Secondary}"
                       Margin="14,8,14,8"/>

            <!-- Optional collapsible Details block. Stays closed by default
                 so the notification renders compact; expanding it reveals
                 a scrollable ItemsControl of Name/Value rows (exception
                 type, HResult, response body, stack trace, etc.). The
                 Expander itself is hidden when Details is empty/null. -->
            <Expander Grid.Row="3"
                      Header="Details"
                      Margin="14,0,14,8"
                      Foreground="{DynamicResource Brush.Text.Muted}"
                      Visibility="{Binding HasDetails, Converter={StaticResource BoolToVis}}">
                <Border BorderBrush="{DynamicResource Brush.Border.Default}"
                        BorderThickness="1"
                        Background="{DynamicResource Brush.Surface.Input}"
                        CornerRadius="{DynamicResource Radius.Small}"
                        Padding="8,6"
                        Margin="0,6,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  MaxHeight="240">
                        <ItemsControl ItemsSource="{Binding Details}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Brush.Text.Muted}"/>
                                        <TextBlock Text="{Binding Value}"
                                                   TextWrapping="Wrap"
                                                   FontFamily="Consolas, Cascadia Mono, Courier New"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Expander>

            <!-- Choice input -->
            <StackPanel Grid.Row="4"
                        Margin="14,0,14,0"
                        Visibility="{Binding IsChoice, Converter={StaticResource BoolToVis}}">
                <ListBox ItemsSource="{Binding Choices}"
                         SelectedItem="{Binding SelectedChoice, Mode=TwoWay}"
                         BorderBrush="{DynamicResource Brush.Border.Default}"
                         BorderThickness="1"
                         Background="{DynamicResource Brush.Surface.Input}"
                         Foreground="{DynamicResource Brush.Text.Primary}"
                         MaxHeight="120"/>
                <StackPanel Margin="0,8,0,0"
                            Visibility="{Binding AllowOther, Converter={StaticResource BoolToVis}}">
                    <RadioButton Content="Other:"
                                 IsChecked="{Binding IsOtherSelected, Mode=TwoWay}"
                                 Foreground="{DynamicResource Brush.Text.Primary}"
                                 GroupName="NotificationOther"/>
                    <TextBox Text="{Binding OtherText, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsOtherSelected}"
                             Margin="20,4,0,0"
                             Padding="4,2"/>
                </StackPanel>
            </StackPanel>

            <!-- TextInput input -->
            <TextBox Grid.Row="4"
                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4"
                     Margin="14,0,14,0"
                     Visibility="{Binding IsTextInput, Converter={StaticResource BoolToVis}}"/>

            <!-- Action buttons -->
            <Grid Grid.Row="5" Margin="14,12,14,14">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Visibility="{Binding IsYesNo, Converter={StaticResource BoolToVis}}">
                    <Button Content="Yes"
                            Width="80"
                            Padding="0,4"
                            Margin="0,0,8,0"
                            Command="{Binding YesCommand}"/>
                    <Button Content="No"
                            Width="80"
                            Padding="0,4"
                            Command="{Binding NoCommand}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Visibility="{Binding IsSubmittable, Converter={StaticResource BoolToVis}}">
                    <Button Content="Submit"
                            Width="80"
                            Padding="0,4"
                            Margin="0,0,8,0"
                            Command="{Binding SubmitCommand}"/>
                    <Button Content="Cancel"
                            Width="80"
                            Padding="0,4"
                            Command="{Binding DismissCommand}"/>
                </StackPanel>
                <!-- Single-action call-to-action (ActionRequest). Primary
                     button uses the severity colour so e.g. "Update now"
                     reads as blue. -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Visibility="{Binding IsAction, Converter={StaticResource BoolToVis}}">
                    <Button Content="{Binding ActionLabel}"
                            MinWidth="100"
                            Padding="10,4"
                            FontWeight="SemiBold"
                            Background="{Binding Severity, Converter={StaticResource SeverityToBrush}}"
                            BorderBrush="{Binding Severity, Converter={StaticResource SeverityToBrush}}"
                            Foreground="{DynamicResource Brush.Text.Inverse}"
                            Command="{Binding InvokeActionCommand}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
